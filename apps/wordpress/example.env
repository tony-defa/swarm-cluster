# Host volume paths
HOST_WORDPRESS_DB=/mnt/wordpress_db
HOST_WORDPRESS_DATA=/mnt/wordpress_data

# WordPress configuration
EXTERNAL_DOMAIN=
## db connection
WORDPRESS_DB_NAME=exampledb1
WORDPRESS_DB_USER=exampleuser1
WORDPRESS_DB_PASSWORD=examplepass1

# MySql configuration
MYSQL_DATABASE=${WORDPRESS_DB_NAME}
MYSQL_USER=${WORDPRESS_DB_USER}
MYSQL_PASSWORD=${WORDPRESS_DB_PASSWORD}
MYSQL_RANDOM_ROOT_PASSWORD='1'

# NFS configuration
NFS_SHARE_IP=