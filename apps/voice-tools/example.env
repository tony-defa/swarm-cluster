# Host volume paths
HOST_PIPER_DATA=/cluster/voice-tools/piper
HOST_FASTER_WHISPER_DATA=/cluster/voice-tools/whisper

# Image tags
PIPER_TAG=latest
FASTER_WHISPER_TAG=latest

# LinuxServer.io standard variables
PUID=1000
PGID=1000
TZ=Etc/UTC

# Piper configuration (https://docs.linuxserver.io/images/docker-piper)
PIPER_VOICE=en_US-lessac-medium
PIPER_LENGTH=1.0
PIPER_NOISE=0.667
PIPER_NOISEW=0.333
PIPER_SPEAKER=0
PIPER_PROCS=1
STREAMING=true

# Faster-Whisper configuration (https://docs.linuxserver.io/images/docker-faster-whisper)
WHISPER_MODEL=base-int8
WHISPER_BEAM=1
WHISPER_LANG=en

# Services shared variables 
LOCAL_ONLY=true

# Ports
PIPER_PORT=10200
FASTER_WHISPER_PORT=10300

# Resource limits
MEM_LIMIT=2g
MEM_RESERVATION=1g
CPU_LIMIT=2.0
CPU_RESERVATION=1.0